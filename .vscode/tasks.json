{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Quran Server",
      "type": "shell",
      "command": "python -m http.server 5500",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": ".*",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Serving HTTP on|serving at"
        }
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ]
}
